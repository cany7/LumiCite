# Example environment file.
# Copy this file to `.env` only when you want to override defaults.
# If a value is not set, the app falls back to the built-in default in code.
# API-related commands still require valid API credentials and base URLs.

# Required for API usage
# Required for `rag query --llm api` and query explanation over API models.
RAG_API_BASE_URL=
# Required for `rag query --llm api` and query explanation over API models.
RAG_API_KEY=
# Optional visual model endpoint; falls back to RAG_API_BASE_URL if empty.
RAG_VISUAL_API_BASE_URL=
# Optional visual model key; falls back to RAG_API_KEY if empty.
RAG_VISUAL_API_KEY=

# Optional overrides

# Embedding
# Controls the embedding model used for vector search.
# Hugging Face embedding model name.
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Number of texts embedded per batch.
RAG_EMBEDDING_BATCH_SIZE=64

# Chunking
# Max characters per chunk before splitting.
RAG_CHUNK_SIZE=1000
# Overlap characters kept between adjacent chunks.
RAG_CHUNK_OVERLAP=100

# Retrieval
# Default top-k used by CLI, API, and RAGPipeline when not passed explicitly.
RAG_RETRIEVAL_TOP_K=10
# Distance cutoff for dense retrieval filtering.
RAG_DISTANCE_THRESHOLD=1.2
# Default retrieval strategy: dense, sparse, or hybrid.
RAG_RETRIEVAL_MODE=hybrid
# Cross-encoder model used for reranking.
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Generation
# Default generation backend: api or ollama.
RAG_LLM_BACKEND=api
# Default API generation model.
RAG_API_MODEL=qwen/qwen3.5-27b
# Request timeout in seconds for the generation API.
RAG_API_TIMEOUT_SECONDS=120
# Reasoning effort for query explanation API calls; use `none` to disable.
RAG_QUERY_EXPLANATION_REASONING_EFFORT=none

# Visual inference
# Default model for visual summarization during parsing.
RAG_VISUAL_API_MODEL=qwen/qwen2.5-vl-7b-instruct
# Request timeout in seconds for visual inference.
RAG_VISUAL_API_TIMEOUT_SECONDS=120

# Ollama
# Base URL of the local Ollama service.
RAG_OLLAMA_BASE_URL=http://localhost:11434
# Default Ollama model for local generation.
RAG_OLLAMA_MODEL=qwen3.5:4b
# Max wait time for Ollama startup in seconds.
RAG_OLLAMA_STARTUP_TIMEOUT_SECONDS=180
# Poll interval in seconds while waiting for Ollama.
RAG_OLLAMA_POLL_INTERVAL_SECONDS=2

# MinerU
# Command used to launch MinerU.
RAG_MINERU_COMMAND=mineru
# Where MinerU downloads or loads its model assets from.
RAG_MINERU_MODEL_SOURCE=huggingface
# Timeout in seconds for a single MinerU run.
RAG_MINERU_TIMEOUT_SECONDS=1800

# Ingestion
# Reserved ingestion worker count for future/background ingestion tasks.
RAG_INGEST_WORKERS=4

# Vector DB
# Vector index backend implementation.
RAG_VECTOR_DB=faiss

# Logging
# Log output format: console or json.
RAG_LOG_FORMAT=console
