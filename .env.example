# Embedding
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_EMBEDDING_BATCH_SIZE=64

# Chunking
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=100

# Retrieval
RAG_RETRIEVAL_TOP_K=5
RAG_DISTANCE_THRESHOLD=1.2
RAG_RETRIEVAL_MODE=hybrid
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Generation
RAG_LLM_BACKEND=api
RAG_API_BASE_URL=
RAG_API_KEY=
RAG_API_MODEL=qwen/qwen3.5-27b
RAG_API_TIMEOUT_SECONDS=120

# Visual inference
RAG_VISUAL_API_BASE_URL=
RAG_VISUAL_API_KEY=
RAG_VISUAL_API_MODEL=qwen/qwen2.5-vl-7b-instruct
RAG_VISUAL_API_TIMEOUT_SECONDS=120

# Ollama
RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_OLLAMA_MODEL=qwen3.5:4b
RAG_OLLAMA_STARTUP_TIMEOUT_SECONDS=180
RAG_OLLAMA_POLL_INTERVAL_SECONDS=2

# MinerU
RAG_MINERU_COMMAND=mineru
RAG_MINERU_MODEL_SOURCE=huggingface
RAG_MINERU_TIMEOUT_SECONDS=1800

# Ingestion
RAG_INGEST_WORKERS=4

# Vector DB
RAG_VECTOR_DB=faiss

# Logging
RAG_LOG_FORMAT=console
